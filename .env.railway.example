# Railway Environment Variables for Fides
# Copy this file to .env and fill in the values

# ========================
# REQUIRED SECRETS
# ========================

# PostgreSQL Password (for fides-db)
POSTGRES_PASSWORD=change_me_generate_strong_password

# Redis Password
REDIS_PASSWORD=change_me_generate_strong_password

# Fides Security - Generate 32+ character random strings
FIDES__SECURITY__APP_ENCRYPTION_KEY=change_me_generate_32_char_random_string

# OAuth Root Client
FIDES__SECURITY__OAUTH_ROOT_CLIENT_ID=fidesadmin
FIDES__SECURITY__OAUTH_ROOT_CLIENT_SECRET=change_me_generate_strong_client_secret

# DRP JWT Secret
FIDES__SECURITY__DRP_JWT_SECRET=change_me_generate_jwt_secret

# ========================
# OPTIONAL CONFIGURATION
# ========================

FIDES__LOGGING__LEVEL=INFO
FIDES__DEV_MODE=false
FIDES__USER__ANALYTICS_OPT_OUT=true
